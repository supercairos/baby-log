# Runtime config for the Docker/nginx container — pass with `docker run -e ...`.
# (Not baked into the image; substituted into the nginx config at container start.)

# Base URL of your Baby Buddy instance that nginx proxies /api to.
# IMPORTANT: no trailing slash and no path — the full /api/... URI is preserved upstream.
BABYBUDDY_UPSTREAM=https://babybuddy.la-ruche.info

# Port nginx listens on inside the container (unprivileged image default is 8080).
PORT=8080
