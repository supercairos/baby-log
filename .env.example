# Dev-time only — used by `npm run fetch:schema:live` and local API poking.
# The RUNTIME app never reads these; it gets its token from the login QR / manual entry.
# Copy to `.env` (gitignored) and fill in.

# Pinned Baby Buddy version whose committed OpenAPI schema we generate types from.
BABYBUDDY_VERSION=2.9.2

# Your instance + a DRF API token (User → Settings → API key, or the "Add a device" QR).
BABYBUDDY_BASE_URL=https://babybuddy.example.com
BABYBUDDY_TOKEN=your-40-char-token
